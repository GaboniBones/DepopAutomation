# Copy this to .env and fill in your Depop login credentials
# The backend will log in automatically and manage the token for you

DEPOP_USERNAME=your_depop_username
DEPOP_PASSWORD=your_depop_password

PORT=5000

# ScraperAPI (no SSN required - sign up free at scraperapi.com)
SCRAPER_API_KEY=your_scraper_api_key
